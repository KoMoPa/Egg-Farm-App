# ============================================================
# Egg Farm App — Test Environment Variables
# Copy this file to .env.test and fill in real values.
# .env.test is git-ignored. NEVER commit real credentials.
# ============================================================

# ── Supabase connection (same project your app uses) ────────
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_key_here

# ── Supabase Service Role key (for admin user mgmt in tests) ─
# Found in Supabase Dashboard → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── Dedicated E2E test user ──────────────────────────────────
# This account will be created (or reset) by global-setup.js
# and deleted by global-teardown.js after every test run.
# Use an address that will never receive real emails.
TEST_USER_EMAIL=e2e-test-user@eggtestfarm.invalid
TEST_USER_PASSWORD=E2eTestP@ss2026!

# ── Test barn name ───────────────────────────────────────────
TEST_BARN_NAME=E2E Test Barn
